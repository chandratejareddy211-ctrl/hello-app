public class HelloAppUC5 {
    public static void main(String[] args) {
        String result;
        if (args.length == 0) {
            result = "lyari";
        } else {
            StringBuilder names = new StringBuilder();
            for (String name : args) {
                if (names.length() > 0) {
                    names.append(", "); 
                }
                names.append(name);
            }

            result = names.toString();
        }
        System.out.println("Salam valekum  " + result + "!");
    }
}
